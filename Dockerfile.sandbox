# syntax=docker/dockerfile:1
#
# Sandbox image — one agent session per container.
# See docs/sandboxed-runner-isolation-plan.md (§8).
#
# Wraps Mintokei.Runner + the agent CLIs so ONE agent session runs inside a
# container as a NON-ROOT user (USER agent, uid 10001). The Docker/Kubernetes
# backends add the rest of the "standard" posture at launch: dropped caps,
# no-new-privileges, and cgroup limits (memory/cpu/pids). Egress is still OPEN by
# default — the allowlist proxy is an opt-in per-profile knob (SandboxEgress.Proxy).
#
# Build (arch is auto-detected by scripts/run-sandbox-spike.sh):
#   docker build -f Dockerfile.sandbox --build-arg RID=linux-x64 -t mintokei/sandbox:spike .

ARG RID=linux-x64

# --- build: publish the runner as a self-contained single-file binary ----------
FROM mcr.microsoft.com/dotnet/sdk:10.0 AS build
ARG RID
WORKDIR /src
COPY src/ ./src/
# Self-contained so the runtime image needs no .NET installed (matches how the
# runner ships as mintokei-runner-<rid>). Restore runs as part of publish.
RUN dotnet publish src/Mintokei.Runner/Mintokei.Runner.csproj \
      -c Release -r "$RID" --self-contained true \
      -p:PublishSingleFile=true -p:IncludeNativeLibrariesForSelfExtract=true \
      -o /out

# --- runtime: node (for the agent CLIs) + git + the runner binary --------------
FROM node:22-bookworm-slim AS runtime

# git → worktrees/clone; libicu → .NET globalization; openssh → git over SSH.
RUN apt-get update && apt-get install -y --no-install-recommends \
      git ca-certificates libicu72 openssh-client \
 && rm -rf /var/lib/apt/lists/*

# Agent CLIs on PATH. Names are fixed host-side (ClaudeBackend => "claude",
# AcpBackends copilot => "copilot", ...). Trim to what you actually test.
RUN npm install -g @anthropic-ai/claude-code @openai/codex \
 && npm cache clean --force
# Other providers, if you test them:
#   npm install -g @github/copilot opencode-ai

# Non-root user the container runs as (see SandboxImage.AgentUid; the backends set
# RunAsUser / tmpfs ownership to this uid). Explicit group so gid 10001 exists
# regardless of the base image's USERGROUPS_ENAB default.
RUN groupadd -g 10001 agent && useradd -m -u 10001 -g 10001 agent
ENV HOME=/home/agent
# The runner is a self-extracting single-file binary; pin native-lib extraction to a writable tmpfs path so it
# still starts under a read-only rootfs (the opt-in ReadOnlyRootfs profile mounts /tmp as tmpfs). Harmless otherwise.
ENV DOTNET_BUNDLE_EXTRACT_BASE_DIR=/tmp/.net
# Repo-provisioning root (prepare-workspace clones here). Pre-create + own it so the
# agent can write when /repos is NOT a mounted volume; a mounted /repos must be made
# writable by uid 10001 out-of-band.
RUN mkdir -p /repos && chown 10001:10001 /repos

# Self-contained publish output: the Mintokei.Runner binary + appsettings.json
# sit side by side; the app finds config via its base directory.
COPY --from=build /out/ /opt/runner/

# Workspace provisioning (Step 2): the entrypoint provisions a source repo from the
# RO mirror via git alternates before the runner connects (only when SANDBOX_REPO_URL
# is set), then execs the runner.
COPY scripts/sandbox/prepare-workspace.sh  /usr/local/bin/prepare-workspace
COPY scripts/sandbox/sandbox-entrypoint.sh /usr/local/bin/sandbox-entrypoint
RUN chmod +x /usr/local/bin/prepare-workspace /usr/local/bin/sandbox-entrypoint

# NOTE: Runner:* config must come via CLI FLAGS, not env vars — Program.cs re-adds
# appsettings.json (which ships BackendUrl + an empty EnrollmentToken) AFTER the
# env-var source, so Runner__BackendUrl / Runner__EnrollmentToken get shadowed.
# Only --backend/--token/--name/--data-dir (added last) win. The entrypoint fixes
# --data-dir /data and passes through the flags run-sandbox-spike.sh appends after
# the image; the runner dials OUT only, so no ports are exposed.

# Drop to the non-root user for the session itself (all root-level setup is done above).
USER agent
ENTRYPOINT ["sandbox-entrypoint"]
